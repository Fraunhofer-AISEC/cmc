#!/bin/bash

set -euo pipefail

trap '[ $? -eq 0 ] && exit 0; printf "%s failed\n" "$0"' EXIT
dir="$(CDPATH='' cd -- "$(dirname -- "$0")/.." && pwd -P)"
source "${dir}/bin/utils.sh"

data="${dir}/data"
cmc="${dir}"
input="${dir}/example-setup/metadata-templates"
out="${data}/metadata-raw"

image_description="${out}/image.description.json"

if [[ ! -d "${data}" ]]; then
  echo "Data directory ${data} does not exist. Did you run the setup-cmc script? Abort.."
  exit 1
fi

if [[ ! -d "${input}" ]]; then
  echo "Data directory ${input} does not exist. Did you run the setup-cmc script? Abort.."
  exit 1
fi

mkdir -p "${out}"

echo "Using ${data} as directory for local data"

# Build cmcctl enclave
cd "${cmc}/cmcctl"
make egocmc

# Get the fingerprint of the Intel SGX Provisioning Certitification Root CA
wget -O "${data}/pki/Intel_SGX_RootCA.pem" https://certificates.trustedservices.intel.com/Intel_SGX_Provisioning_Certification_RootCA.pem
fingerprint=$(openssl x509 -in "${data}/pki/Intel_SGX_RootCA.pem" -fingerprint -noout -sha256 | sed 's/://g' | cut -d "=" -f2)

# Get MRENCLAVE reference value
mrenclave=$(echo "$(ego uniqueid cmcctl)" | awk 'NR==1')
components='[
    {
      "type": ar.TYPE_REFVAL_SGX,
      "name": "MRENCLAVE",
      "index": 0,
      "sha256": "'"${mrenclave}"'",
      "description": "MRENCLAVE"
    }
]'

# Get MRSIGNER enclave signer hash
mrsigner=$(echo "$(ego signerid cmcctl)" | awk 'NR==1')

cd "${data}"

# SBOM: load
sbom=$(cat "${input}/cyclonedx.sbom.json")

# SBOM: Insert reference values
setarr "sbom" "components" "${components}"

# SBOM: Set other properties
setjson "sbom" "bomFormat"   "CycloneDX"
setjson "sbom" "specVersion" "\"1.7\""
setjson "sbom" "version"     1

# Load manifest template
manifest=$(cat "${input}/manifest.json")

name="de.test.rtm"

# Insert manifest properties
setjson "manifest" "name"                  "${name}"
setjson "manifest" "version"               "$(date -u +"%Y-%m-%dT%H:%M:%SZ")"
setjson "manifest" "developerCommonName"   "test developer"
setjson "manifest" "validity.notBefore"    "$(date -u +"%Y-%m-%dT%H:%M:%SZ" -d "-1 day")"
setjson "manifest" "validity.notAfter"     "$(date -u +"%Y-%m-%dT%H:%M:%SZ" -d "+2 years")"
setjson "manifest" "description"           "RTM Manifest"
setarr  "manifest" "baseLayers"            "${name}"
setjson "manifest" "certLevel"             3
setjson "manifest" "caFingerprint"         "${fingerprint}"
setjson "manifest" "sbom"                  "${sbom}"

# Create policy
policy=$(cat "${input}/sgx.policy.json")
setjson "policy" "quoteVersion"                 3
setjson "policy" "attributes.initted"           true
setjson "policy" "attributes.debug"             false
setjson "policy" "attributes.mode64Bit"         true
setjson "policy" "attributes.provisionKey"      false
setjson "policy" "attributes.eInitToken"        false
setjson "policy" "attributes.kss"               false
setjson "policy" "attributes.legacy"            false
setjson "policy" "attributes.avx"               false
setjson "policy" "isvSvn"                       1
setjson "policy" "mrsigner"                     "${mrsigner}"

setjson "manifest" "sgxPolicy" "${policy}"

# Save the manifest
echo "Writing ${out}/rtm.manifest.json"
printf "%s\n" "${manifest}" > "${out}/rtm.manifest.json"

# Manifest Description: Create corresponding manifest description
rtmdesc=$(cat "${input}/manifest.description.json")
setjson "rtmdesc" "name"     "${name}.description"
setjson "rtmdesc" "manifest" "${name}"

# Image Description: Add/replace manifest description to/in image description
image_description=$(cat "${image_description}")
exists=$(echo "${image_description}" | jq "any(.descriptions[]; .name == \"${name}.description\")")
if [[ "${exists}" = false ]]; then
  echo "Adding manifest description to image description"
else
  echo "Replacing existing Manifest description"
  image_description=$(echo "$image_description" | jq ".descriptions |= map(select(.name != \"${name}.description\"))")
fi
extendarr "image_description" "descriptions" "${rtmdesc}"

# Image Description: Store
echo "Writing ${image_description}"
printf "%s\n" "${image_description}" > "${image_description}"
