#!/bin/bash

set -euo pipefail

trap '[ $? -eq 0 ] && exit 0; printf "%s failed\n" "$0"' EXIT
dir="$(CDPATH='' cd -- "$(dirname -- "$0")/.." && pwd -P)"
source "${dir}/bin/utils.sh"

bin="${dir}/bin"

"${bin}/generate-image-description" "tdx-device.test.de"

"${bin}/precompute-rtm-manifest-tdx" --omsp "https://localhost:9000/omsp"

"${bin}/precompute-os-manifest-tdx" --omsp "https://localhost:9000/omsp"
