#!/bin/bash

set -euo pipefail

trap '[ $? -eq 0 ] && exit 0; printf "%s failed\n" "$0"' EXIT
dir="$(CDPATH='' cd -- "$(dirname -- "$0")/.." && pwd -P)"
source "${dir}/bin/utils.sh"

data="${dir}/data"
input="${data}/metadata-signed"
out="${data}/omsp-raw"

if [[ ! -d "${data}" ]]; then
  echo "Data directory ${data} does not exist. Did you run the setup-cmc script? Abort.."
  exit 1
fi

if [[ ! -d "${input}" ]]; then
  echo "Data directory ${input} does not exist. Did you run sign-metadata first? Abort.."
  exit 1
fi

# Clean start
rm -rf "${out}"

mkdir -p "${out}"

echo "Using ${data} as directory for local data"

for path in ${input}/*.manifest.*; do
	echo "Generating OMSP response for $path"
	json="{}"
	hash=$(sha256sum "${path}" | cut -d' ' -f1)

	# Insert manifest hash and revocation status
	setjson "json" "manifestHash" "$hash"
	setjson "json" "status"       "good"
	setjson "json" "thisUpdate"   "$(date -u +"%Y-%m-%dT%H:%M:%SZ")"
	setjson "json" "nextUpdate"   "$(date -u +"%Y-%m-%dT%H:%M:%SZ" -d "+7 days")"
	# Save OMSP response content
	outfile="${hash}.json"
	echo "Writing ${out}/${outfile}"
	printf "%s\n" "${json}" > "${out}/${outfile}"
done
