#!/bin/bash

set -euo pipefail

trap '[ $? -eq 0 ] && exit 0; printf "%s failed\n" "$0"' EXIT
dir="$(CDPATH='' cd -- "$(dirname -- "$0")/.." && pwd -P)"
source "${dir}/bin/utils.sh"

data="${dir}/data"
input="${dir}/example-setup/metadata-templates"
out="${data}/metadata-raw"
image_description="${out}/image.description.json"

images="${dir}/vm/images"
vm_config="${dir}/example-setup/vm-config"
artifacts="${dir}/vm/artifacts"

if [[ ! -d "${data}" ]]; then
  echo "Data directory ${data} does not exist. Did you run the setup-cmc script? Abort.."
  exit 1
fi

if [[ ! -d "${input}" ]]; then
  echo "Data directory ${input} does not exist. Did you run the setup-cmc script? Abort.."
  exit 1
fi

mkdir -p "${out}"

echo "Using ${data} as directory for local data"

# Retrieve os details
set +e
kernel=$(uname -r)
os=$(lsb_release -sd 2>/dev/null)
set -e

# Precompute the values of the OS PCRs
refs_tpm=$(mrtool precompute tpm \
    --mrs 8,9 \
    --kernel "${artifacts}/vmlinuz" \
    --initrd "${artifacts}/initrd" \
    --cmdline "${vm_config}/cmdline" \
    --grubcmds "${vm_config}/grub_cmds" \
    --path "${artifacts}/grub" \
    --path "${artifacts}/vmlinuz" \
    --path "${artifacts}/initrd" \
)

# SBOM: load
sbom=$(cat "${input}/cyclonedx.sbom.json")

# SBOM: Insert reference values in the OS Manifest
setarr "sbom" "components" "${refs_tpm}"

# SBOM: Set other properties
setjson "sbom" "bomFormat"   "CycloneDX"
setjson "sbom" "specVersion" "\"1.7\""
setjson "sbom" "version"     1

# Load OS manifest
manifest=$(cat "${input}/manifest.manifest")

name="de.test.os"

# Insert manifest properties
setjson "manifest" "name"                  "${name}"
setjson "manifest" "version"               "$(date -u +"%Y-%m-%dT%H:%M:%SZ")"
setjson "manifest" "developerCommonName"   "test developer"
setjson "manifest" "validity.notBefore"    "$(date -u +"%Y-%m-%dT%H:%M:%SZ" -d "-1 day")"
setjson "manifest" "validity.notAfter"     "$(date -u +"%Y-%m-%dT%H:%M:%SZ" -d "+2 years")"
setjson "manifest" "description"           "OS Manifest"
setarr  "manifest" "baseLayers"            "de.test.rtm"
setjson "manifest" "certLevel"             3
setjson "manifest" "sbom"                  "${sbom}"
setjson "manifest" "details.kernel" "${kernel}"
setjson "manifest" "details.os" "${os}"

# Save manifest
echo "Writing ${out}/rtm.manifest.json"
printf "%s\n" "${manifest}" > "${out}/os.manifest.json"

# OS Manifest Description: Create corresponding OS manifest description
osdesc=$(cat "${input}/manifest.description.json")
setjson "osdesc" "name"     "${name}.description"
setjson "osdesc" "manifest" "${name}"

# Image Description: Add/replace os manifest description to/in image description
image_description=$(cat "${image_description}")
exists=$(echo "${image_description}" | jq "any(.descriptions[]; .name == \"${name}.description\")")
if [[ "${exists}" = false ]]; then
  echo "Adding OS Manifest description to image description"
else
  echo "Replacing existing OS Manifest description"
  image_description=$(echo "$image_description" | jq ".descriptions |= map(select(.name != \"${name}.description\"))")
fi
extendarr "image_description" "descriptions" "${osdesc}"

# Image Description: Store
echo "Writing ${image_description}"
printf "%s\n" "${image_description}" > "${image_description}"

