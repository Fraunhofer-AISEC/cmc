#!/bin/bash

set -euo pipefail

trap '[ $? -eq 0 ] && exit 0; printf "%s failed\n" "$0"' EXIT
dir="$(CDPATH='' cd -- "$(dirname -- "$0")/.." && pwd -P)"
source "${dir}/bin/utils.sh"

# If ssh is not specified, the reference values are parsed from the local machine. If SSH is
# specified, the reference values are parsed from the remote, where the mrtool must be installed
if [[ $# -eq 0 ]]; then
  mrtool=(sudo "${dir}/tools/mrtool/mrtool")
elif [[ $# -eq 1 ]]; then
  mrtool=("$1" mrtool)
elif [[ $# -eq 2 ]]; then
  mrtool=("$1" "$2" mrtool)
else
  echo "Usage: $(basename $0) [ssh]"
  exit 1
fi

data="${dir}/data"
input="${dir}/example-setup/metadata-templates"
out="${data}/metadata-raw"

image_description_path="${out}/image.description.json"

if [[ ! -d "${data}" ]]; then
  echo "Data directory ${1} does not exist. Did you run the setup-cmc script? Abort.."
  exit 1
fi

if [[ ! -d "${input}" ]]; then
  echo "Data directory ${input} does not exist. Did you run the setup-cmc script? Abort.."
  exit 1
fi

mkdir -p "${out}"

echo "Using ${data} as directory for local data"

# Retrieve reference values from event logs if present, otherwise retrieve final PCR values from TPM
if [[ -f "/sys/kernel/security/tpm0/binary_bios_measurements" ]]; then
  echo "TPM event log present: parsing eventlog"
  components=$("${mrtool[@]}" parse tpm --mrs 0,1,2,3,4,5,6,7)
else
  echo "TPM event log not present: reading final PCR values"
  components=$("${mrtool[@]}" read tpm --mrs 0,1,2,3,4,5,6,7)
fi

# SBOM: load
sbom=$(cat "${input}/cyclonedx.sbom.json")

# SBOM: Replace existing reference values with new reference values
setarr "sbom" "components" "${components}"

# SBOM: Set other properties
setjson "sbom" "bomFormat"   "CycloneDX"
setjson "sbom" "specVersion" "\"1.7\""
setjson "sbom" "version"     1

# Manifest: load
manifest=$(cat "${input}/manifest.json")

name="de.test.rtm"

# Insert manifest properties
setjson "manifest" "name"                  "${name}"
setjson "manifest" "version"               "$(date -u +"%Y-%m-%dT%H:%M:%SZ")"
setjson "manifest" "developerCommonName"   "test developer"
setjson "manifest" "validity.notBefore"    "$(date -u +"%Y-%m-%dT%H:%M:%SZ" -d "-1 day")"
setjson "manifest" "validity.notAfter"     "$(date -u +"%Y-%m-%dT%H:%M:%SZ" -d "+2 years")"
setjson "manifest" "description"           "RTM Manifest"
setarr  "manifest" "baseLayers"            "${name}"
setjson "manifest" "certLevel"             3
setjson "manifest" "sbom"                  "${sbom}"

# Save the RTM manifest
echo "Writing ${out}/rtm.manifest.json"
printf "%s\n" "${manifest}" > "${out}/rtm.manifest.json"

# RTM Manifest Description: Create corresponding RTM manifest description
rtmdesc=$(cat "${input}/manifest.description.json")
setjson "rtmdesc" "name"     "${name}.description"
setjson "rtmdesc" "manifest" "${name}"

# Image Description: Add/replace RTM manifest description to/in image description
image_description=$(cat "${image_description_path}")
exists=$(echo "${image_description}" | jq "any(.descriptions[]; .name == \"${name}.description\")")
if [[ "${exists}" = false ]]; then
  echo "Adding RTM manifest description to image description"
else
  echo "Replacing existing RTM Manifest description"
  image_description=$(echo "$image_description" | jq ".descriptions |= map(select(.name != \"${name}.description\"))")
fi
extendarr "image_description" "descriptions" "${rtmdesc}"

# Image Description: Store
echo "Writing ${image_description_path}"
printf "%s\n" "${image_description}" > "${image_description_path}"
