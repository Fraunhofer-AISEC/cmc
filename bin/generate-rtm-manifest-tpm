#!/bin/bash

set -euo pipefail

trap '[ $? -eq 0 ] && exit 0; printf "%s failed\n" "$0"' EXIT
dir="$(CDPATH='' cd -- "$(dirname -- "$0")/.." && pwd -P)"

metatool="${dir}/tools/metatool/metatool"

# If ssh is not specified, the reference values are parsed from the local machine. If SSH is
# specified, the reference values are parsed from the remote, where the mrtool must be installed
if [[ $# -eq 0 ]]; then
  mrtool=(sudo "${dir}/tools/mrtool/mrtool")
elif [[ $# -eq 1 ]]; then
  mrtool=("$1" mrtool)
elif [[ $# -eq 2 ]]; then
  mrtool=("$1" "$2" mrtool)
else
  echo "Usage: $(basename $0) [ssh]"
  exit 1
fi

data="${dir}/data"
out="${data}/metadata-raw"

name="de.test.rtm"
image_description_path="${out}/image.description.json"

if [[ ! -d "${data}" ]]; then
  echo "Data directory ${1} does not exist. Did you run the setup-cmc script? Abort.."
  exit 1
fi

mkdir -p "${out}"

echo "Using ${data} as directory for local data"

# Retrieve reference values from event logs if present, otherwise retrieve final PCR values from TPM
if [[ -f "/sys/kernel/security/tpm0/binary_bios_measurements" ]]; then
  echo "TPM event log present: parsing eventlog"
  components=$("${mrtool[@]}" parse tpm --mrs 0,1,2,3,4,5,6,7)
else
  echo "TPM event log not present: reading final PCR values"
  components=$("${mrtool[@]}" read tpm --mrs 0,1,2,3,4,5,6,7)
fi

# Create RTM manifest
echo "Writing ${out}/rtm.manifest.json"
"${metatool}" create manifest \
  --name "${name}" \
  --version "$(date -u +"%Y-%m-%dT%H:%M:%SZ")" \
  --developer-common-name "test developer" \
  --not-before "$(date -u +"%Y-%m-%dT%H:%M:%SZ" -d "-1 day")" \
  --not-after "$(date -u +"%Y-%m-%dT%H:%M:%SZ" -d "+2 years")" \
  --description "RTM Manifest" \
  --base-layers "${name}" \
  --cert-level 3 \
  --sbom-format CycloneDX \
  --components "${components}" \
  --out "${out}/rtm.manifest.json"

# Create RTM manifest description and add to image description
desc_tmp=$(mktemp)
"${metatool}" create manifest-description \
  --name "${name}.description" \
  --manifest "${name}" \
  --out "${desc_tmp}"

echo "Writing ${image_description_path}"
"${metatool}" create image-description \
  --in "${image_description_path}" \
  --add-description "${desc_tmp}" \
  --out "${image_description_path}"
rm -f "${desc_tmp}"
