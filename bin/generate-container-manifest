#!/bin/bash

set -euo pipefail

trap '[ $? -eq 0 ] && exit 0; printf "%s failed\n" "$0"' EXIT
dir="$(CDPATH='' cd -- "$(dirname -- "$0")/.." && pwd -P)"

metatool="${dir}/tools/metatool/metatool"

print_usage() {
  echo "Usage: $(basename "$0") <container-engine> <container> [<container arguments>]"
  echo "       container-engine: docker, ctr, docker-compose, runc"
  echo "       container: depends on the engine, e.g."
  echo "              docker/ctr:     docker.io/library/ubuntu:22.04"
  echo "              docker-compose: docker-compose.yaml"
  echo "              runc:           /path/to/runtime-bundle"
  echo "      container arguments: additional container cmdline parameters"
}

if [[ "$#" -lt 2 ]]; then
  print_usage
  exit 1
fi

# Extract the -env parameters
keys=()
values=()
found=false
for arg in "$@"; do
    if [[ "${arg}" == "-env" ]]; then
        found=true
    elif [[ "${found}" == true ]]; then
        IFS='=' read -r KEY VAL <<< "$arg"
        keys+=("${KEY}")
        values+=("${VAL}")
        found=false
    fi
done

# Set all parameters
client="$1"
shift
target="$1"
shift
args="$@"

data="${dir}/data"
cmc="${dir}"
out="${data}/metadata-raw"

runtime="${cmc}/tools/containerd-shim-cmc-v1/containerd-shim-cmc-v1"
runc_config="/etc/runc-measure-conf.json"
target="${target%/}"
image_description_path="${out}/image.description.json"

if [[ ! -d "${data}" ]]; then
  echo "Data directory ${data} does not exist. Did you run the setup-cmc script? Abort.."
  exit 1
fi

if [[ ! -f "${image_description_path}" ]]; then
    echo "Error: image description ${image_description_path} does not exist. Run generate-image-description first"
    exit 1
fi

echo "Creating reference values for container: ${target} with args ${args}"
echo "Using ${data} as directory for local data"

mkdir -p "${out}"

# Temporarily configure runc to generate reference values
if [[ ! -f "${runc_config}" ]]; then
    exists=false
    echo "{\"generateRefVals\":\"true\"}" | tee "${runc_config}"
else
  exists=true
  json=$(cat "${runc_config}")
  original_json=${json}
  json=$(echo "${json}" | jq '.generateRefVals = true')
  echo "${json}" | sudo tee "${runc_config}"
fi

# Calculate the container reference values
sudo rm -f /tmp/container-refs

echo "Generating reference values for ${client} client"
if  [[ "${client}" == "ctr" ]]; then
    containers=("${target}")
    sudo ctr image pull "${target}"
    set +e
    sudo ctr run --detach ${args} "${target}" REF_CONTAINER
    sudo ctr task kill -s SIGKILL REF_CONTAINER
    sudo ctr container delete REF_CONTAINER
    set -e
elif  [[ "${client}" == "shim" ]]; then
    containers=("${target}")
    sudo ctr image pull "${target}"
    set +e
    sudo ctr run --runtime "${runtime}" -t --rm ${args} "${target}" CMC_GENERATE_APP_MANIFEST
    set -e
elif [[ "${client}" == "docker" ]]; then
    containers=("${target}")
    sudo docker run ${args} "${target}"
elif [[ "${client}" == "docker-compose" ]]; then
    containers=($(yq '.services | keys | .[]' "${target}"))
    set +e
    docker compose -f "${target}" up &
    echo "Sleeping for 10s to enable container start"
    sleep 10
    echo "Stopping containers"
    docker compose -f "${target}" stop
    sleep 3
    set -e
elif [[ "${client}" == "runc" ]]; then
    containers=("${target}")
    cd "${target}"
    sudo runc create references
    sudo runc delete references
    cd -
else
    echo "Client ${client} not supported. Only 'docker', 'docker-compose', 'ctr' and 'runc' supported"
    exit
fi

# Restore the original runc config
if [[ "${exists}" = true ]] ; then
 echo "${original_json}" | sudo tee "${runc_config}"
else
  sudo rm "${runc_config}"
fi

refvals=$(cat /tmp/container-refs)

# In some scenarios, e.g. docker-compose, we have more than one container and have to iterate over all
num_containers=$(echo "${refvals}" | jq length)
for ((i = 0; i < num_containers; i++)); do
    echo "Creating manifest for container $i"

    container=${containers[$i]}

    refval=$(echo "${refvals}" | jq -r ".[$i]")

    # Build the SBOM with components and extract SHA256 for unique naming
    sbom=$(jq -n \
      --arg fmt "CycloneDX" \
      --arg spec "1.7" \
      --argjson ver 1 \
      --argjson comp "${refval}" \
      '{bomFormat: $fmt, specVersion: $spec, version: $ver, components: (if $comp | type == "array" then $comp else [$comp] end)}')

    sha256=$(echo "${sbom}" | jq -r '.components[0].hashes[0].content')
    container_name=$(echo "${container}-oci" | sed 's:.*/::' | tr : -)
    container_name="${container_name}-${sha256:0:8}"

    # Rename the component
    sbom=$(echo "${sbom}" | jq --arg name "${container_name}" '.components[0].name = $name')

    # Save SBOM to temp file for metatool
    sbom_tmp=$(mktemp)
    echo "${sbom}" > "${sbom_tmp}"

    # Create container manifest
    echo "Writing ${out}/${container_name}.manifest.json"
    "${metatool}" create manifest \
      --name "${container_name}" \
      --version "$(date -u +"%Y-%m-%dT%H:%M:%SZ")" \
      --developer-common-name "test developer" \
      --not-before "$(date -u +"%Y-%m-%dT%H:%M:%SZ" -d "-1 day")" \
      --not-after "$(date -u +"%Y-%m-%dT%H:%M:%SZ" -d "+2 years")" \
      --description "App Manifest" \
      --base-layers "de.test.os" \
      --cert-level 1 \
      --sbom "${sbom_tmp}" \
      --out "${out}/${container_name}.manifest.json"
    rm -f "${sbom_tmp}"

    # Create app manifest description
    desc_tmp=$(mktemp)
    "${metatool}" create manifest-description \
      --name "${container_name}.description" \
      --manifest "${container_name}" \
      --out "${desc_tmp}"

    # Add environment variables to the description if present
    if [[ ${#keys[@]} -gt 0 ]]; then
        echo "Adding environment variables"
        for j in "${!keys[@]}"; do
            envs="{\"key\": \"${keys[${j}]}\", \"value\": \"${values[${j}]}\"}"
            echo "Adding $envs"
            desc_json=$(cat "${desc_tmp}")
            echo "${desc_json}" | jq --argjson envs "${envs}" '.environment += [$envs]' > "${desc_tmp}"
        done
    fi

    # Add manifest description to image description
    echo "Writing ${image_description_path}"
    "${metatool}" create image-description \
      --in "${image_description_path}" \
      --add-description "${desc_tmp}" \
      --out "${image_description_path}"
    rm -f "${desc_tmp}"
done
