#!/bin/bash

set -euo pipefail

trap '[ $? -eq 0 ] && exit 0; printf "%s failed\n" "$0"' EXIT
dir="$(CDPATH='' cd -- "$(dirname -- "$0")/.." && pwd -P)"

metatool="${dir}/tools/metatool/metatool"

# Extract OMSP endpoint from parameters
omsp=""

i=1
while [[ $i -le $# ]]; do
  arg="${!i}"
  case "$arg" in
    --omsp) 
      (( i++ ))
      omsp="${!i}"
      ;;
    *)
      echo "Usage: $(basename $0) [--omsp <omsp endpoint>]"
      exit 1
      ;;
  esac
  (( i++ ))
done

data="${dir}/data"
out="${data}/metadata-raw"

images="${dir}/vm/images"
vm_config="${dir}/example-setup/vm-config"
artifacts="${dir}/vm/artifacts"

if [[ ! -d "${data}" ]]; then
  echo "Data directory ${1} does not exist. Did you run the setup-cmc script? Abort.."
  exit 1
fi

mkdir -p "${out}"

echo "Using ${data} as directory for local data"

# Get the fingerprint of the TPM privacy CA that was used for credential activation
fingerprint=$(openssl x509 -in "${data}/pki/ca.pem" -fingerprint -noout -sha256 | sed 's/://g' | cut -d "=" -f2)

# Precompute the values of the RTM PCRs
printf "[\033[34;1m EXEC \033[0m] Precompute PCRs\n"
components=$(mrtool precompute tpm \
    --mrs 0,1,2,3,4,5,6,7 \
    --ovmf "${images}/OVMF.fd" \
    --bootloaders "${artifacts}/shimx64.efi","${artifacts}/grubx64.efi" \
    --config "${vm_config}/mrtool.json" \
    --acpirsdp "${vm_config}/etc-acpi-rsdp" \
    --acpitables "${vm_config}/etc-acpi-tables" \
    --tableloader "${vm_config}/etc-table-loader" \
    --tpmlog "${vm_config}/etc-tpm-log" \
    --sbatlevel "${artifacts}/efivars/SbatLevelRT-605dab50-e046-4300-abb6-3dd810dd8b23" \
    --gpt "${artifacts}/ev_efi_gpt_event" \
)

name="de.test.rtm"

# Create RTM manifest
echo "Writing ${out}/rtm.manifest.json"
"${metatool}" create manifest \
  --name "${name}" \
  --version "$(date -u +"%Y-%m-%dT%H:%M:%SZ")" \
  --developer-common-name "test developer" \
  --not-before "$(date -u +"%Y-%m-%dT%H:%M:%SZ" -d "-1 day")" \
  --not-after "$(date -u +"%Y-%m-%dT%H:%M:%SZ" -d "+2 years")" \
  --description "RTM Manifest" \
  --base-layers "${name}" \
  --cert-level 3 \
  --ca-fingerprints "${fingerprint}" \
  --sbom-format CycloneDX \
  --components "${components}" \
  --omsp "${omsp}" \
  --out "${out}/rtm.manifest.json"

# Create manifest description and add to image description
desc_tmp=$(mktemp)
"${metatool}" create manifest-description \
  --name "${name}.description" \
  --manifest "${name}" \
  --out "${desc_tmp}"

echo "Writing ${out}/image.description.json"
"${metatool}" create image-description \
  --in "${out}/image.description.json" \
  --add-description "${desc_tmp}" \
  --out "${out}/image.description.json"
rm -f "${desc_tmp}"
