#!/bin/bash

set -euo pipefail

trap '[ $? -eq 0 ] && exit 0; printf "%s failed\n" "$0"' EXIT
dir="$(CDPATH='' cd -- "$(dirname -- "$0")/.." && pwd -P)"

metatool="${dir}/tools/metatool/metatool"

# If ssh is not specified, the reference values are parsed from the local machine. If SSH is
# specified, the reference values are parsed from the remote, where the mrtool must be installed
if [[ $# -eq 0 ]]; then
  mrtool=(sudo "${dir}/tools/mrtool/mrtool")
elif [[ $# -eq 1 ]]; then
  mrtool=("$1" mrtool)
elif [[ $# -eq 2 ]]; then
  mrtool=("$1" "$2" mrtool)
else
  echo "Usage: $(basename $0) [ssh]"
  exit 1
fi

data="${dir}/data"
out="${data}/metadata-raw"

name="de.test.host-apps"
image_description_path="${out}/image.description.json"

if [[ ! -d "${data}" ]]; then
  echo "Data directory ${data} does not exist. Did you run the setup-cmc script? Abort.."
  exit 1
fi

if [[ ! -f "${image_description_path}" ]]; then
    echo "Error: image description ${image_description_path} does not exist. Run generate-image-description first"
    exit 1
fi

echo "Using ${data} as directory for local data"

# Parse the IMA measurement lists
components=$("${mrtool[@]}" parse ima --mrs 10)

# Create app manifest
echo "Writing ${out}/app.manifest.json"
"${metatool}" create manifest \
  --name "${name}" \
  --version "$(date -u +"%Y-%m-%dT%H:%M:%SZ")" \
  --developer-common-name "test developer" \
  --not-before "$(date -u +"%Y-%m-%dT%H:%M:%SZ" -d "-1 day")" \
  --not-after "$(date -u +"%Y-%m-%dT%H:%M:%SZ" -d "+2 years")" \
  --description "App Manifest" \
  --base-layers "de.test.os" \
  --cert-level 1 \
  --sbom-format CycloneDX \
  --components "${components}" \
  --out "${out}/app.manifest.json"

# Create app manifest description and add to image description
desc_tmp=$(mktemp)
"${metatool}" create manifest-description \
  --name "${name}.description" \
  --manifest "${name}" \
  --out "${desc_tmp}"

echo "Writing ${image_description_path}"
"${metatool}" create image-description \
  --in "${image_description_path}" \
  --add-description "${desc_tmp}" \
  --out "${image_description_path}"
rm -f "${desc_tmp}"
