{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$ref": "#/$defs/AttestationReport",
  "$defs": {
    "AttestationReport": {
      "properties": {
        "version": {
          "type": "string"
        },
        "type": {
          "type": "string"
        },
        "name": {
          "type": "string"
        },
        "encoding": {
          "type": "string"
        },
        "evidences": {
          "items": {
            "$ref": "#/$defs/Evidence"
          },
          "type": "array"
        }
      },
      "type": "object"
    },
    "Evidence": {
      "properties": {
        "type": {
          "type": "string"
        },
        "evidence": {
          "type": "string",
          "contentEncoding": "base64"
        },
        "addData": {
          "type": "string",
          "contentEncoding": "base64"
        },
        "signature": {
          "type": "string",
          "contentEncoding": "base64"
        }
      },
      "type": "object"
    }
  }
}