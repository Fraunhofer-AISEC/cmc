{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$ref": "#/$defs/TLSSignRequest",
  "$defs": {
    "TLSSignRequest": {
      "properties": {
        "version": {
          "type": "string"
        },
        "keyId": {
          "type": "string"
        },
        "content": {
          "type": "string",
          "contentEncoding": "base64"
        },
        "hashAlg": {
          "type": "string",
          "enum": [
            "SHA-256",
            "SHA-384",
            "SHA-512"
          ]
        }
      },
      "type": "object"
    }
  }
}