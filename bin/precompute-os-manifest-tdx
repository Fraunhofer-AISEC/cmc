#!/bin/bash

set -euo pipefail

trap '[ $? -eq 0 ] && exit 0; printf "%s failed\n" "$0"' EXIT
dir="$(CDPATH='' cd -- "$(dirname -- "$0")/.." && pwd -P)"

metatool="${dir}/tools/metatool/metatool"

# Extract OMSP endpoint from parameters
omsp=""

i=1
while [[ $i -le $# ]]; do
  arg="${!i}"
  case "$arg" in
    --omsp) 
      (( i++ ))
      omsp="${!i}"
      ;;
    *)
      echo "Usage: $(basename $0) [--omsp <omsp endpoint>]"
      exit 1
      ;;
  esac
  (( i++ ))
done

# TODO set this to paths where your reproducible build outputs the required artifacts
artifacts="${dir}/artifacts"

data="${dir}/data"
out="${data}/metadata-raw"
image_description_path="${out}/image.description.json"

if [[ ! -d "${data}" ]]; then
  echo "Data directory ${1} does not exist. Did you run the setup-cmc script? Abort.."
  exit 1
fi

mkdir -p "${out}"

echo "Using ${data} as directory for local data"

# Generate Intel SGX Root CA fingerprint
echo "Calculating Intel SGX Root CA fingerprint"
wget -O "${data}/pki/Intel_SGX_RootCA.pem" https://certificates.trustedservices.intel.com/Intel_SGX_Provisioning_Certification_RootCA.pem
fingerprint=$(openssl x509 -in "${data}/pki/Intel_SGX_RootCA.pem" -fingerprint -noout -sha256 | sed 's/://g' | cut -d "=" -f2)

# Generate reference values
echo "Calculating reference values"
components=$(mrtool precompute tdx \
    --mrs 2,3,4 \
    --tdxmodule "${artifacts}/intel_tdx_module.so" \
    --ovmf "${artifacts}/OVMF.fd" \
    --kernel "${artifacts}/linux-amd64-tdx-systemd-debug.bzImage" \
    --cmdline "${artifacts}/linux-amd64-tdx-systemd-debug.cmdline" \
    --config "${artifacts}/calculate-pcrs.cfg" \
    --acpirsdp "${artifacts}/etc-acpi-rsdp" \
    --acpitables "${artifacts}/etc-acpi-tables" \
    --tableloader "${artifacts}/etc-table-loader" \
)

name="de.test.os"

# Create OS manifest
echo "Writing ${out}/os.manifest.json"
"${metatool}" create manifest \
  --name "${name}" \
  --version "$(date -u +"%Y-%m-%dT%H:%M:%SZ")" \
  --developer-common-name "test developer" \
  --not-before "$(date -u +"%Y-%m-%dT%H:%M:%SZ" -d "-1 day")" \
  --not-after "$(date -u +"%Y-%m-%dT%H:%M:%SZ" -d "+2 years")" \
  --description "OS Manifest" \
  --base-layers "de.test.rtm" \
  --cert-level 3 \
  --ca-fingerprints "${fingerprint}" \
  --sbom-format CycloneDX \
  --components "${components}" \
  --omsp "${omsp}" \
  --out "${out}/os.manifest.json"

# Create OS manifest description and add to image description
desc_tmp=$(mktemp)
"${metatool}" create manifest-description \
  --name "${name}.description" \
  --manifest "${name}" \
  --out "${desc_tmp}"

echo "Writing ${image_description_path}"
"${metatool}" create image-description \
  --in "${image_description_path}" \
  --add-description "${desc_tmp}" \
  --out "${image_description_path}"
rm -f "${desc_tmp}"
