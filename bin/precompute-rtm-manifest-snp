#!/bin/bash

set -euo pipefail

trap '[ $? -eq 0 ] && exit 0; printf "%s failed\n" "$0"' EXIT
dir="$(CDPATH='' cd -- "$(dirname -- "$0")/.." && pwd -P)"

metatool="${dir}/tools/metatool/metatool"

# Default values
ovmf="${dir}/vm/images/OVMF-AWS.fd"
vcpus=2
vmm_type=ec2

# Parse arguments
while [[ $# -gt 0 ]]; do
  case "$1" in
    --vcpus)
      vcpus="$2"
      shift 2
      ;;
    --vmm-type)
      vmm_type="$2"
      shift 2
      ;;
    --ovmf)
      ovmf="$2"
      shift 2
      ;;
    *)
      echo "Unknown option: $1"
      echo "Usage: $0 [--vcpus #] [--vmm-type TYPE] [--ovmf PATH]"
      exit 1
      ;;
  esac
done

data="${dir}/data"
out="${data}/metadata-raw"
pki="${data}/pki"
image_description_path="${out}/image.description.json"

if [[ ! -d "${data}" ]]; then
  echo "Data directory ${data} does not exist. Did you run the setup-cmc script? Abort.."
  exit 1
fi

mkdir -p "${out}"

echo "Using ${data} as directory for local data"

# Get AMD cert chains and collect CA fingerprints
snp_code_names=("Milan" "Genoa" "Turin")
snp_ark_names=("ark_milan.pem" "ark_genoa.pem" "ark_turin.pem")
ca_fingerprints=""

for i in "${!snp_code_names[@]}"; do
    code="${snp_code_names[$i]}"
    ark="${snp_ark_names[$i]}"
    ark_file="${pki}/${ark}"

    if [[ ! -f "${ark_file}" ]]; then
      echo "Fetching AMD SEV-SNP ${code} CA..."
      wget -qO "${pki}/Cert_Chain_${code}" "https://kdsintf.amd.com/vlek/v1/${code}/cert_chain"
      awk '/-----BEGIN CERTIFICATE-----/{n++} n==2' "${pki}/Cert_Chain_${code}" > "${ark_file}"
    fi
    fingerprint=$(openssl x509 -in "${ark_file}" -fingerprint -noout -sha256 | sed 's/://g' | cut -d "=" -f2)
    if [[ -n "${ca_fingerprints}" ]]; then
      ca_fingerprints="${ca_fingerprints},${fingerprint}"
    else
      ca_fingerprints="${fingerprint}"
    fi
done

# Precompute SNP reference values
components=$("${dir}/tools/mrtool/mrtool" precompute snp \
  --vcpus "${vcpus}" \
  --vmm-type "${vmm_type}" \
  --ovmf "${ovmf}" \
)

# Create SNP version entries
tmp_versions=$(mktemp -d)

"${metatool}" create snp-version \
  --name "milan" \
  --fw-major 1 --fw-minor 55 --fw-build 17 \
  --tcb-bl 4 --tcb-tee 0 --tcb-snp 21 --tcb-ucode 211 \
  --out "${tmp_versions}/milan.json"

"${metatool}" create snp-version \
  --name "genoa" \
  --fw-major 1 --fw-minor 55 --fw-build 39 \
  --tcb-bl 8 --tcb-tee 0 --tcb-snp 23 --tcb-ucode 21 \
  --out "${tmp_versions}/genoa.json"

"${metatool}" create snp-version \
  --name "turin" \
  --fw-major 1 --fw-minor 55 --fw-build 61 \
  --tcb-fmc 0 --tcb-bl 1 --tcb-tee 0 --tcb-snp 2 --tcb-ucode 71 \
  --out "${tmp_versions}/turin.json"

# Create SNP policy
policy_tmp=$(mktemp)
"${metatool}" create snp-policy \
  --report-min-version 2 --report-max-version 5 \
  --smt \
  --versions "${tmp_versions}/milan.json,${tmp_versions}/genoa.json,${tmp_versions}/turin.json" \
  --out "${policy_tmp}"
rm -rf "${tmp_versions}"

name="de.test.rtm"

# Create RTM manifest
printf "Writing %s\n" "${out}/rtm.manifest.json"
"${metatool}" create manifest \
  --name "${name}" \
  --version "$(date -u +"%Y-%m-%dT%H:%M:%SZ")" \
  --developer-common-name "test developer" \
  --not-before "$(date -u +"%Y-%m-%dT%H:%M:%SZ" -d "-1 day")" \
  --not-after "$(date -u +"%Y-%m-%dT%H:%M:%SZ" -d "+2 years")" \
  --description "RTM Manifest" \
  --base-layers "${name}" \
  --cert-level 3 \
  --ca-fingerprints "${ca_fingerprints}" \
  --snp-policy "${policy_tmp}" \
  --sbom-format CycloneDX \
  --components "${components}" \
  --out "${out}/rtm.manifest.json"
rm -f "${policy_tmp}"

# Create manifest description and add to image description
desc_tmp=$(mktemp)
"${metatool}" create manifest-description \
  --name "${name}.description" \
  --manifest "${name}" \
  --out "${desc_tmp}"

echo "Writing ${image_description_path}"
"${metatool}" create image-description \
  --in "${image_description_path}" \
  --add-description "${desc_tmp}" \
  --out "${image_description_path}"
rm -f "${desc_tmp}"
