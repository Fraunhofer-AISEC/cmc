#!/bin/bash

set -euo pipefail

trap '[ $? -eq 0 ] && exit 0; printf "%s failed\n" "$0"' EXIT
dir="$(CDPATH='' cd -- "$(dirname -- "$0")/.." && pwd -P)"
source "${dir}/bin/utils.sh"

bin="${dir}/bin"

"${bin}/generate-image-description" "test-vm.test.de"

"${bin}/generate-rtm-manifest-tpm" --omsp "https://10.0.2.2:9000/omsp" "vm-ssh"

"${bin}/generate-os-manifest-tpm" --omsp "https://10.0.2.2:9000/omsp" "vm-ssh"

"${bin}/generate-app-manifest-tpm" --omsp "https://10.0.2.2:9000/omsp" "vm-ssh"