#!/bin/bash

set -euo pipefail

trap '[ $? -eq 0 ] && exit 0; printf "%s failed\n" "$0"' EXIT
dir="$(CDPATH='' cd -- "$(dirname -- "$0")/.." && pwd -P)"

metatool="${dir}/tools/metatool/metatool"

data="${dir}/data"
cmc="${dir}"
out="${data}/metadata-raw"
image_description_path="${out}/image.description.json"

if [[ ! -d "${data}" ]]; then
  echo "Data directory ${data} does not exist. Did you run the setup-cmc script? Abort.."
  exit 1
fi

mkdir -p "${out}"

echo "Using ${data} as directory for local data"

# Build cmcctl enclave
cd "${cmc}/cmcctl"
make egocmc

# Get the fingerprint of the Intel SGX Provisioning Certitification Root CA
wget -O "${data}/pki/Intel_SGX_RootCA.pem" https://certificates.trustedservices.intel.com/Intel_SGX_Provisioning_Certification_RootCA.pem
fingerprint=$(openssl x509 -in "${data}/pki/Intel_SGX_RootCA.pem" -fingerprint -noout -sha256 | sed 's/://g' | cut -d "=" -f2)

# Get MRENCLAVE reference value
mrenclave=$(echo "$(ego uniqueid cmcctl)" | awk 'NR==1')
components='[
    {
      "type": "SGX Reference Value",
      "name": "MRENCLAVE",
      "index": 0,
      "hashes": [{"alg": "SHA-256", "content": "'"${mrenclave}"'"}],
      "description": "MRENCLAVE"
    }
]'

# Get MRSIGNER enclave signer hash
mrsigner=$(echo "$(ego signerid cmcctl)" | awk 'NR==1')

cd "${data}"

# Create SGX policy
policy_tmp=$(mktemp)
"${metatool}" create sgx-policy \
  --quote-version 3 \
  --initted \
  --mode64bit \
  --isv-svn 1 \
  --mr-signer "${mrsigner}" \
  --out "${policy_tmp}"

name="de.test.rtm"

# Create RTM manifest
echo "Writing ${out}/rtm.manifest.json"
"${metatool}" create manifest \
  --name "${name}" \
  --version "$(date -u +"%Y-%m-%dT%H:%M:%SZ")" \
  --developer-common-name "test developer" \
  --not-before "$(date -u +"%Y-%m-%dT%H:%M:%SZ" -d "-1 day")" \
  --not-after "$(date -u +"%Y-%m-%dT%H:%M:%SZ" -d "+2 years")" \
  --description "RTM Manifest" \
  --base-layers "${name}" \
  --cert-level 3 \
  --ca-fingerprints "${fingerprint}" \
  --sgx-policy "${policy_tmp}" \
  --sbom-format CycloneDX \
  --components "${components}" \
  --out "${out}/rtm.manifest.json"
rm -f "${policy_tmp}"

# Create manifest description and add to image description
desc_tmp=$(mktemp)
"${metatool}" create manifest-description \
  --name "${name}.description" \
  --manifest "${name}" \
  --out "${desc_tmp}"

echo "Writing ${image_description_path}"
"${metatool}" create image-description \
  --in "${image_description_path}" \
  --add-description "${desc_tmp}" \
  --out "${image_description_path}"
rm -f "${desc_tmp}"
