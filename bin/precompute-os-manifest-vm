#!/bin/bash

set -euo pipefail

trap '[ $? -eq 0 ] && exit 0; printf "%s failed\n" "$0"' EXIT
dir="$(CDPATH='' cd -- "$(dirname -- "$0")/.." && pwd -P)"

metatool="${dir}/tools/metatool/metatool"

# Extract OMSP endpoint from parameters
omsp=""

i=1
while [[ $i -le $# ]]; do
  arg="${!i}"
  case "$arg" in
    --omsp) 
      (( i++ ))
      omsp="${!i}"
      ;;
    *)
      echo "Usage: $(basename $0) [--omsp <omsp endpoint>]"
      exit 1
      ;;
  esac
  (( i++ ))
done

data="${dir}/data"
out="${data}/metadata-raw"
image_description_path="${out}/image.description.json"

images="${dir}/vm/images"
vm_config="${dir}/example-setup/vm-config"
artifacts="${dir}/vm/artifacts"

if [[ ! -d "${data}" ]]; then
  echo "Data directory ${data} does not exist. Did you run the setup-cmc script? Abort.."
  exit 1
fi

mkdir -p "${out}"

echo "Using ${data} as directory for local data"

# Retrieve os details
set +e
kernel=$(uname -r)
os=$(lsb_release -sd 2>/dev/null)
set -e

# Precompute the values of the OS PCRs
components=$(mrtool precompute tpm \
    --mrs 8,9 \
    --kernel "${artifacts}/vmlinuz" \
    --initrd "${artifacts}/initrd" \
    --cmdline "${vm_config}/cmdline" \
    --grubcmds "${vm_config}/grub_cmds" \
    --path "${artifacts}/grub" \
    --path "${artifacts}/vmlinuz" \
    --path "${artifacts}/initrd" \
)

name="de.test.os"

# Create OS manifest
echo "Writing ${out}/os.manifest.json"
"${metatool}" create manifest \
  --name "${name}" \
  --version "$(date -u +"%Y-%m-%dT%H:%M:%SZ")" \
  --developer-common-name "test developer" \
  --not-before "$(date -u +"%Y-%m-%dT%H:%M:%SZ" -d "-1 day")" \
  --not-after "$(date -u +"%Y-%m-%dT%H:%M:%SZ" -d "+2 years")" \
  --description "OS Manifest" \
  --base-layers "de.test.rtm" \
  --cert-level 3 \
  --details "kernel=${kernel},os=${os}" \
  --sbom-format CycloneDX \
  --components "${components}" \
  --omsp "${omsp}" \
  --out "${out}/os.manifest.json"

# Create OS manifest description and add to image description
desc_tmp=$(mktemp)
"${metatool}" create manifest-description \
  --name "${name}.description" \
  --manifest "${name}" \
  --out "${desc_tmp}"

echo "Writing ${image_description_path}"
"${metatool}" create image-description \
  --in "${image_description_path}" \
  --add-description "${desc_tmp}" \
  --out "${image_description_path}"
rm -f "${desc_tmp}"
